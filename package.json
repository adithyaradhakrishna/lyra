{
  "name": "lyra",
  "publisher": "adithyaradhakrishna",
  "displayName": "LYRA - Learns How You Learn",
  "description": "Proactive mentor for beginner coders – detects struggles, gives emotional support + fixes automatically",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/adithyaradhakrishna/lyra.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onDiagnosticChange"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lyra.showHelp",
        "title": "LYRA: Open Help Sidebar"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lyra-sidebar",
          "title": "LYRA Mentor",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "lyra-sidebar": [
        {
          "id": "lyra.help",
          "name": "Help & Encouragement"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js",
    "build": "echo 'Build completed'",
    "start": "node api/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^10.0.1",
    "globals": "^17.3.0"
  },
  "dependencies": {
    "openai": "^4.52.7"
  }
}
